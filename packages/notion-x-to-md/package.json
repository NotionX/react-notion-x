{
  "name": "notion-x-to-md",
  "version": "7.10.0",
  "type": "module",
  "description": "Converts a Notion page to Markdown. Very useful for LLMs.",
  "repository": "NotionX/react-notion-x",
  "author": "Travis Fischer <travis@transitivebullsh.it>",
  "license": "MIT",
  "source": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "notion-x-to-md": "./src/cli.ts"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "watch": "tsup --watch --silent --onSuccess 'echo build successful'",
    "clean": "del build",
    "test": "run-s test:*",
    "test:typecheck": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "date-fns": "catalog:",
    "format-number": "catalog:",
    "notion-client": "workspace:*",
    "notion-types": "workspace:*",
    "notion-utils": "workspace:*",
    "p-map": "catalog:",
    "tweet-to-md": "^1.0.5"
  },
  "keywords": [
    "notion",
    "md",
    "markdown",
    "gfm",
    "llm",
    "ai",
    "chat",
    "chatbot",
    "chatgpt",
    "openai",
    "gpt"
  ],
  "publishConfig": {
    "access": "public",
    "files": [
      "build"
    ],
    "types": "./build/index.d.ts",
    "bin": {
      "notion-x-to-md": "./build/cli.js"
    },
    "exports": {
      ".": {
        "types": "./build/index.d.ts",
        "import": "./build/index.js",
        "default": "./build/index.js"
      }
    }
  }
}
